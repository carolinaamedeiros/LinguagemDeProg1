<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.FarmController">
   <children>
      <Label fx:id="lbNomeFunc" layoutX="50.0" layoutY="119.0" text="Nome do funcionário:" />
      <Label fx:id="lbSalario" layoutX="48.0" layoutY="189.0" text="Calculadora de salário:" />
      <Label fx:id="lbSexoFunc" layoutX="50.0" layoutY="262.0" text="Sexo do funcionário:" />
      <TextField fx:id="txtNomeFunc" layoutX="226.0" layoutY="115.0" />
      <TextField fx:id="txtSalario" layoutX="227.0" layoutY="187.0" />
      <TextField fx:id="txtSexoFunc" layoutX="226.0" layoutY="260.0" />
      <Label layoutX="246.0" layoutY="36.0" text="FUNCIONÁRIOS:">
         <font>
            <Font name="Arial Black" size="12.0" />
         </font>
      </Label>
      <Button fx:id="btCadastrarNome" layoutX="444.0" layoutY="115.0" mnemonicParsing="false" onAction="#cadastrarNomeFunc" text="Cadastrar" />
      <Button fx:id="btCalcularSalario" layoutX="446.0" layoutY="187.0" mnemonicParsing="false" onAction="#calcularSalarioFunc" text="Calcular" />
      <Button fx:id="btCadastrarSexo" layoutX="444.0" layoutY="260.0" mnemonicParsing="false" onAction="#cadastrarSexoFunc" text="Cadastrar" />
   </children>
</AnchorPane>
