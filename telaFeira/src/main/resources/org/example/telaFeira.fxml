<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.FeiraController">
   <children>
      <Label fx:id="lbComida" layoutX="65.0" layoutY="104.0" text="Comida:" />
      <Label fx:id="lbValor" layoutX="66.0" layoutY="192.0" text="Valor:" />
      <Label fx:id="lbTipo" layoutX="68.0" layoutY="282.0" text="Tipo:" />
      <TextField fx:id="txtComida" layoutX="199.0" layoutY="100.0" />
      <TextField fx:id="txtValor" layoutX="199.0" layoutY="188.0" />
      <TextField fx:id="txtTipo" layoutX="199.0" layoutY="278.0" />
      <Text layoutX="195.0" layoutY="41.0" strokeType="OUTSIDE" strokeWidth="0.0" text="CADASTRO DE ALIMENTOS">
         <font>
            <Font name="Arial Black" size="14.0" />
         </font>
      </Text>
      <Button fx:id="btCadastrar" layoutX="233.0" layoutY="331.0" mnemonicParsing="false" onAction="#cadastrar" text="Cadastrar" />
      <Button fx:id="btProduto" layoutX="445.0" layoutY="176.0" mnemonicParsing="false" onAction="#exibirProdutos" text="Exibir produtos" />
      <Button fx:id="btCategoria" layoutX="442.0" layoutY="233.0" mnemonicParsing="false" onAction="#exibirCategorias" text="Exibir categorias" />
   </children>
</AnchorPane>
